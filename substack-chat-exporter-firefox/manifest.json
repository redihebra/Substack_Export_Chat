{
  "manifest_version": 3,
  "name": "Substack Chat Exporter",
  "version": "1.2",
  "description": "Export Substack chat threads to markdown",
  "browser_specific_settings": {
    "gecko": {
      "id": "{d3b3f5a2-7c1e-4e8a-9f2b-1a5c8d6e4f3b}",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "cookies",
    "downloads",
    "activeTab"
  ],
  "host_permissions": [
    "https://substack.com/*",
    "https://*.substack.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
